-- Player List'i başlangıçta doldur
local function GetPlayerList()
    local players = {}
    for _, p in Players:GetPlayers() do
        if p ~= player then
            table.insert(players, p.DisplayName .. " (@" .. p.Name .. ")")
        end
    end
    if #players == 0 then
        players = { "No players in server" }
    end
    return players
end

