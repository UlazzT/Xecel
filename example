-- Highlight ve Click detection
local UserInputService = game:GetService("UserInputService")
local RunService = game:GetService("RunService")
local clickConnection
local highlightConnection
local currentHighlight

Toggles.ClickToSteal:OnChanged(function(Value)
    if Value then
        -- Toggle açıldı, hover ve click detection'ı başlat
        
        -- Mouse ile üzerine gelinen oyuncuyu highlight yap
        highlightConnection = RunService.RenderStepped:Connect(function()
            local mouse = player:GetMouse()
            local target = mouse.Target
            
            -- Önce eski highlight'ı temizle
            if currentHighlight then
                currentHighlight:Destroy()
                currentHighlight = nil
            end
            
            if target then
                local character = target:FindFirstAncestorOfClass("Model")
                if character then
                    local targetPlayer = Players:GetPlayerFromCharacter(character)
                    
                    if targetPlayer and targetPlayer ~= player and character:FindFirstChild("Humanoid") then
                        -- Yeni highlight oluştur
                        local highlight = Instance.new("Highlight")
                        highlight.Name = "StealHighlight"
                        highlight.FillColor = Color3.fromRGB(255, 0, 0)
                        highlight.FillTransparency = 0.5
                        highlight.OutlineColor = Color3.fromRGB(255, 0, 0)
                        highlight.OutlineTransparency = 0
                        highlight.Parent = character
                        currentHighlight = highlight
                        
                        -- Tooltip göster
                        mouse.Icon = "rbxasset://SystemCursors/Cross"
                    end
                end
            end
            
            -- Mouse icon'unu sıfırla
            if not currentHighlight then
                mouse.Icon = ""
            end
        end)
        
        -- Click detection
        clickConnection = UserInputService.InputBegan:Connect(function(input, gameProcessed)
            if gameProcessed then return end
            if input.UserInputType == Enum.UserInputType.MouseButton1 then
                local mouse = player:GetMouse()
                local target = mouse.Target
                
                if target then
                    local character = target:FindFirstAncestorOfClass("Model")
                    if character then
                        local targetPlayer = Players:GetPlayerFromCharacter(character)
                        
                        if targetPlayer and targetPlayer ~= player and character:FindFirstChild("Humanoid") then
                            -- Avatar tipini dropdown'dan al
                            local avatarType = Options.AvatarType.Value
                            local rig = avatarType == "R6" and Enum.HumanoidRigType.R6 or Enum.HumanoidRigType.R15
                            local saveOutfit = Toggles.SaveOutfit and Toggles.SaveOutfit.Value or false
                            local rs = game:GetService("ReplicatedStorage")
                            
                            pcall(function()
                                local desc = character.Humanoid:GetAppliedDescription()
                                local wear = {{
                                    ["Properties"] = {
                                        ["WalkAnimation"] = desc.WalkAnimation, ["MoodAnimation"] = desc.MoodAnimation,
                                        ["Face"] = desc.Face, ["ProportionScale"] = desc.ProportionScale,
                                        ["ClimbAnimation"] = desc.ClimbAnimation, ["Shirt"] = desc.Shirt,
                                        ["FaceAccessory"] = desc.FaceAccessory,
                                        ["RightArmColor"] = {r = math.floor(desc.RightArmColor.R * 255), g = math.floor(desc.RightArmColor.G * 255), b = math.floor(desc.RightArmColor.B * 255), IsRGBTable = true},
                                        ["HairAccessory"] = desc.HairAccessory, ["RightArm"] = desc.RightArm,
                                        ["Head"] = desc.Head, ["FallAnimation"] = desc.FallAnimation,
                                        ["TorsoColor"] = {r = math.floor(desc.TorsoColor.R * 255), g = math.floor(desc.TorsoColor.G * 255), b = math.floor(desc.TorsoColor.B * 255), IsRGBTable = true},
                                        ["DepthScale"] = desc.DepthScale, ["LeftArm"] = desc.LeftArm,
                                        ["HeightScale"] = desc.HeightScale, ["LeftLeg"] = desc.LeftLeg,
                                        ["RightLegColor"] = {r = math.floor(desc.RightLegColor.R * 255), g = math.floor(desc.RightLegColor.G * 255), b = math.floor(desc.RightLegColor.B * 255), IsRGBTable = true},
                                        ["LeftLegColor"] = {r = math.floor(desc.LeftLegColor.R * 255), g = math.floor(desc.LeftLegColor.G * 255), b = math.floor(desc.LeftLegColor.B * 255), IsRGBTable = true},
                                        ["WidthScale"] = desc.WidthScale, ["BodyTypeScale"] = desc.BodyTypeScale,
                                        ["RunAnimation"] = desc.RunAnimation,
                                        ["LeftArmColor"] = {r = math.floor(desc.LeftArmColor.R * 255), g = math.floor(desc.LeftArmColor.G * 255), b = math.floor(desc.LeftArmColor.B * 255), IsRGBTable = true},
                                        ["Pants"] = desc.Pants, ["WaistAccessory"] = desc.WaistAccessory,
                                        ["LayeredAccessories"] = {}, ["AccessoryRefinements"] = {},
                                        ["ShouldersAccessory"] = desc.ShouldersAccessory, ["NeckAccessory"] = desc.NeckAccessory,
                                        ["HatAccessory"] = desc.HatAccessory, ["FrontAccessory"] = desc.FrontAccessory,
                                        ["SwimAnimation"] = desc.SwimAnimation,
                                        ["HeadColor"] = {r = math.floor(desc.HeadColor.R * 255), g = math.floor(desc.HeadColor.G * 255), b = math.floor(desc.HeadColor.B * 255), IsRGBTable = true},
                                        ["BackAccessory"] = desc.BackAccessory, ["IdleAnimation"] = desc.IdleAnimation,
                                        ["Torso"] = desc.Torso, ["HeadScale"] = desc.HeadScale,
                                        ["JumpAnimation"] = desc.JumpAnimation, ["GraphicTShirt"] = desc.GraphicTShirt,
                                        ["RightLeg"] = desc.RightLeg
                                    },
                                    ["Action"] = "CreateAndWearHumanoidDescription",
                                    ["RigType"] = rig
                                }}
                                
                                rs.CatalogGuiRemote:InvokeServer(unpack(wear))
                                
                                if saveOutfit then
                                    local outfitName = "Stolen from " .. targetPlayer.DisplayName .. " (@" .. targetPlayer.Name .. ")"
                                    rs.Events.SavedOutfitsRemote:InvokeServer({ OutfitName = outfitName, Configs = {}, Action = "CreateNewOutfit" })
                                end
                                
                                Library:Notify({
                                    Title = "Stolen!",
                                    Description = "Avatar stolen from " .. targetPlayer.DisplayName .. " (@" .. targetPlayer.Name .. ")!",
                                    Time = 2
                                })
                            end)
                        end
                    end
                end
            end
        end)
    else
        -- Toggle kapandı, tüm detection'ları durdur
        if clickConnection then
            clickConnection:Disconnect()
            clickConnection = nil
        end
        
        if highlightConnection then
            highlightConnection:Disconnect()
            highlightConnection = nil
        end
        
        if currentHighlight then
            currentHighlight:Destroy()
            currentHighlight = nil
        end
        
        -- Mouse icon'unu sıfırla
        pcall(function()
            player:GetMouse().Icon = ""
        end)
    end
end)

